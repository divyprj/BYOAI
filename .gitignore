# ============================================================
# BYOAI — Git Ignore Rules
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
*.whl

# Virtual environments
venv/
.venv/
env/
ENV/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.pytype/

# ------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------
.env
!.env.example

# ------------------------------------------------------------
# ML / Model Artifacts
# ------------------------------------------------------------
*.pt
*.pth
*.bin
*.onnx
*.safetensors
model-cache/
models/

# HuggingFace cache
.cache/

# ------------------------------------------------------------
# MLflow
# ------------------------------------------------------------
mlruns/
mlflow.db
mlartifacts/

# ------------------------------------------------------------
# Data Pipeline
# ------------------------------------------------------------
data_pipeline/processed/
data_pipeline/output/

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
*.log

# ------------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ------------------------------------------------------------
# OS Files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ------------------------------------------------------------
# Node (if frontend added later)
# ------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.bak
*.tmp
*.temp
