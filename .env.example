# ============================================================
# BYOAI - Environment Configuration
# ============================================================
# Copy this file to .env and customize values for your setup.
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Gateway Configuration (Service 1 - :8000)
# ------------------------------------------------------------
GATEWAY_ML_SERVICE_URL=http://ml-service:8001
GATEWAY_RATE_LIMIT_REQUESTS=60
GATEWAY_RATE_LIMIT_WINDOW=60
GATEWAY_LOG_LEVEL=INFO

# ------------------------------------------------------------
# ML Service Configuration (Service 2 - :8001)
# ------------------------------------------------------------
ML_MODEL_NAME=facebook/bart-large-mnli
ML_DEVICE=cpu
ML_MAX_LENGTH=512
ML_CONFIDENCE_THRESHOLD=0.3
ML_LOG_LEVEL=INFO

# ------------------------------------------------------------
# MLflow Configuration (Service 3 - :5000)
# ------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
